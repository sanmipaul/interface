# ──────────────────────────────────────────────────────────────────────────────
# SO4 — Environment variables
# Copy this file to .env.local (for local dev) and fill in real values.
# All VITE_ vars are inlined by Vite at build time and visible in the bundle.
# Never put private keys or secrets in VITE_ variables.
# ──────────────────────────────────────────────────────────────────────────────

# ── Network ───────────────────────────────────────────────────────────────────

# "testnet" | "mainnet"
VITE_NETWORK=testnet

# ── RPC / Horizon ─────────────────────────────────────────────────────────────
# Soroban JSON-RPC endpoint.
# Provider list: https://developers.stellar.org/docs/data/apis/rpc/providers
VITE_RPC_URL=https://soroban-testnet.stellar.org

# Horizon REST API endpoint.
VITE_HORIZON_URL=https://horizon-testnet.stellar.org

# ── Oracle ────────────────────────────────────────────────────────────────────
# Price-feed base URL. Optional — falls back to GMX infra if unset.
# VITE_ORACLE_URL=https://arbitrum-api.gmxinfra.io

# Pyth Hermes endpoint for on-chain price attestations.
# VITE_PYTH_HERMES_URL=https://hermes.pyth.network

# ── Contract addresses ────────────────────────────────────────────────────────
# All Soroban contract IDs (C... StrKey addresses) for the active network.
VITE_CONTRACT_EXCHANGE_ROUTER=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_CONTRACT_SYNTHETICS_READER=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_CONTRACT_DATA_STORE=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_CONTRACT_ORDER_VAULT=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_CONTRACT_STAKING_ROUTER=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_CONTRACT_GLV_ROUTER=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_CONTRACT_VESTING_ROUTER=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_CONTRACT_REFERRAL_STORAGE=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
